#!/bin/bash
set -e # Exit immediately if a command exits with a non-zero status.

cd $(dirname $0) # Move to the directory of the script

OB_TEAM_SCRIPTS_REPO=https://github.com/rancher/ob-charts-tool.git
OB_TEAM_SCRIPT_VERSION="${OB_TEAM_SCRIPT_VERSION:-latest}"

CACHE_FILE="../bin/.ob-version-check-cache"
CACHE_MAX_AGE=86400 # 24 hours in seconds

# Function to fetch the latest version from GitHub
fetch_latest_version() {
    curl --silent "https://api.github.com/repos/rancher/ob-charts-tool/releases/latest" | jq -r '.tag_name'
}

# Function to get the latest version with caching
get_latest_version() {
    local now=$(date +%s)
    local cache_valid=false

    # Check if cache exists and is recent
    if [[ -f "$CACHE_FILE" ]]; then
        local cache_time=$(head -n 1 "$CACHE_FILE")
        local cache_age=$((now - cache_time))

        if [[ $cache_age -lt $CACHE_MAX_AGE ]]; then
            cache_valid=true
        fi
    fi

    # Use cache or fetch new version
    if [[ "$cache_valid" == "true" ]]; then
        tail -n 1 "$CACHE_FILE"
    else
        local latest=$(fetch_latest_version)
        # Update cache
        mkdir -p "$(dirname "$CACHE_FILE")"
        echo "$now" > "$CACHE_FILE"
        echo "$latest" >> "$CACHE_FILE"
        echo "$latest"
    fi
}

# Check if the ob-charts-tool binary exists in the ../bin directory
if ls ../bin/ob-charts-tool 1>/dev/null 2>/dev/null; then
    # Use awk to split the version output correctly and extract the version number
    CURRENT_SCRIPT_VERSION="$(../bin/ob-charts-tool --version | awk '{print $3}')"
    echo "Current version: ${CURRENT_SCRIPT_VERSION}, Expected version: ${OB_TEAM_SCRIPT_VERSION}"

    # If the version is "latest", resolve it using cached check
    if [[ "${OB_TEAM_SCRIPT_VERSION}" == "latest" ]]; then
        OB_TEAM_SCRIPT_VERSION=$(get_latest_version)
        echo "Resolved latest version to ${OB_TEAM_SCRIPT_VERSION}"
    fi

    # Exit if the current version matches the expected version
    if [[ "${CURRENT_SCRIPT_VERSION}" == "${OB_TEAM_SCRIPT_VERSION}" ]]; then
        # Warn if a newer version is available (only when using a pinned version)
        if [[ "${OB_TEAM_SCRIPT_VERSION}" != "latest" ]]; then
            LATEST_AVAILABLE=$(get_latest_version)
            if [[ "${CURRENT_SCRIPT_VERSION}" != "${LATEST_AVAILABLE}" ]]; then
                echo "⚠️  Warning: A newer version is available: ${LATEST_AVAILABLE}"
                echo "   Current version: ${CURRENT_SCRIPT_VERSION}"
                echo "   To upgrade, set OB_TEAM_SCRIPT_VERSION=${LATEST_AVAILABLE} or set to 'latest'"
            fi
        fi

        exit 0
    fi
fi

# If the version is "latest", resolve it using cached check
if [[ "${OB_TEAM_SCRIPT_VERSION}" == "latest" ]]; then
    echo "Expected the latest version!"
    OB_TEAM_SCRIPT_VERSION=$(get_latest_version)
    echo "Resolved latest version to ${OB_TEAM_SCRIPT_VERSION}"
fi

echo "Downloading ob-charts-tool version ${OB_TEAM_SCRIPTS_REPO}@${OB_TEAM_SCRIPT_VERSION}"

# Remove existing ../bin directory and change to the parent dir.
rm -f ../bin/ob-charts-tool
cd ..

mkdir -p bin # Re-create bin dir

# Extract the OS and architecture from the go version command output
OS=$(go version | cut -d' ' -f4 | cut -d'/' -f1)
ARCH=$(go version | cut -d' ' -f4 | cut -d'/' -f2)

# Determine the binary name based on the OS and architecture
if [[ "$OS" == "windows" ]]; then
    BINARY_NAME="ob-charts-tool_${OS}_${ARCH}.exe"
else
    BINARY_NAME="ob-charts-tool_${OS}_${ARCH}"
fi

# Download the binary from the ob-charts-tool repository
BASE_URL="${OB_TEAM_SCRIPTS_REPO%.git}/releases/download/${OB_TEAM_SCRIPT_VERSION}"
echo "Downloading ${BASE_URL}/${BINARY_NAME}"
HTTP_CODE=$(curl -s -L -w "%{http_code}" -o bin/ob-charts-tool "${BASE_URL}/${BINARY_NAME}")
if [[ ! "$HTTP_CODE" =~ ^[0-9]+$ ]] || [[ "$HTTP_CODE" -ne 200 ]]; then
    echo "Error downloading ${BINARY_NAME}, HTTP code: $HTTP_CODE"
    rm -f bin/ob-charts-tool
    exit 1
fi

# Download and verify checksums
# The checksums filename embeds the version number without the leading 'v' (e.g. ob-charts-tool_0.3.1_checksums.txt)
CHECKSUMS_NAME="ob-charts-tool_${OB_TEAM_SCRIPT_VERSION#v}_checksums.txt"
echo "Downloading ${CHECKSUMS_NAME} for verification"
HTTP_CODE=$(curl -s -L -w "%{http_code}" -o bin/ob-charts-tool.checksums.txt "${BASE_URL}/${CHECKSUMS_NAME}")
if [[ ! "$HTTP_CODE" =~ ^[0-9]+$ ]] || [[ "$HTTP_CODE" -ne 200 ]]; then
    echo "Error downloading ${CHECKSUMS_NAME}, HTTP code: $HTTP_CODE"
    rm -f bin/ob-charts-tool bin/ob-charts-tool.checksums.txt
    exit 1
fi

echo "Verifying checksum"
EXPECTED_CHECKSUM=$(grep "  ${BINARY_NAME}$" bin/ob-charts-tool.checksums.txt | awk '{print $1}')
if [[ -z "$EXPECTED_CHECKSUM" ]]; then
    echo "Error: no checksum entry found for ${BINARY_NAME} in ${CHECKSUMS_NAME}"
    rm -f bin/ob-charts-tool bin/ob-charts-tool.checksums.txt
    exit 1
fi
ACTUAL_CHECKSUM=$(sha256sum bin/ob-charts-tool | awk '{print $1}')
if [[ "$ACTUAL_CHECKSUM" != "$EXPECTED_CHECKSUM" ]]; then
    echo "Error: checksum mismatch for ${BINARY_NAME}"
    echo "  Expected: ${EXPECTED_CHECKSUM}"
    echo "  Actual:   ${ACTUAL_CHECKSUM}"
    rm -f bin/ob-charts-tool bin/ob-charts-tool.checksums.txt
    exit 1
fi
echo "Checksum verified: ${ACTUAL_CHECKSUM}"
rm -f bin/ob-charts-tool.checksums.txt

echo "${BINARY_NAME} => ./bin/ob-charts-tool"

chmod +x ./bin/ob-charts-tool
./bin/ob-charts-tool --version