{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Renovate manages GitHub Actions workflows. Chart artifacts in charts/ are published releases and cannot be automatically updated.",
  "extends": [
    "github>rancher/renovate-config#release"
  ],
  "baseBranches": [
    "main"
  ],
  "enabled": true,
  "enabledManagers": [
    "github-actions"
  ],
  "prHourlyLimit": 2,
  "prConcurrentLimit": 3,
  "packageRules": [
    {
      "matchBaseBranches": ["main"],
      "extends": ["github>rancher/renovate-config:rancher-main#main"]
    },
    {
      "groupName": "GitHub Workflow Actions",
      "groupSlug": "gha-deps",
      "matchManagers": ["github-actions"]
    }
  ]
}
